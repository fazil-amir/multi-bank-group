{
  "name": "multibank-crypto-dashboard",
  "version": "1.0.0",
  "type": "module",
  "private": true,
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev:server": "tsx watch src/server/index.ts",
